{
  "name": "2026-cdde",
  "version": "1.0.0",
  "scripts": {
    "build": "vite build",
    "postbuild": "node -e \"const fs=require('fs'),path=require('path');fs.writeFileSync('dist/.nojekyll','');fs.readdirSync('dist').filter(f=>f.endsWith('.html')).forEach(f=>{const p=path.join('dist',f);const h=fs.readFileSync(p,'utf8');fs.writeFileSync(p,h.replace(/href=\\\"\\//g,'href=\\\"./').replace(/src=\\\"\\//g,'src=\\\"./'));});\"",
    "start": "vite --open",
    "start_public": "vite --open --host",
    "preview": "vite preview",
    "format": "biome format --write src",
    "lint:fix": "biome check --write src",
    "login": "az login --service-principal -u $AZURE_USER -p $AZURE_PW --tenant $AZURE_TENANT",
    "data:dependence-map": "node scripts/convert-dependence-map.mjs",
    "data:exports-by-region": "python3 scripts/convert-exports-by-region.py",
    "data:dependence-by-group": "python3 scripts/convert-dependence-by-group.py",
    "data:dependence-by-level": "python3 scripts/convert-dependence-by-level.py",
    "data:commodity-prices": "python3 scripts/convert-commodity-prices.py",
    "data:status-change": "python3 scripts/convert-status-change.py",
    "data:dependence-movers": "python3 scripts/convert-dependence-movers.py",
    "data:all": "npm run data:dependence-map && npm run data:exports-by-region && npm run data:dependence-by-group && npm run data:dependence-by-level && npm run data:status-change && npm run data:dependence-movers",
    "push": "git push && git push unctad main",
    "sync-gh-pages": "git subtree push --prefix dist origin gh-pages",
    "sync-prod": "azcopy copy \"dist/*\" \"https://${AZURE_STORAGE_NAME}.blob.core.windows.net/\\$web/${npm_package_name}/\" --include-path 'js;css;assets' --recursive --exclude-pattern '.DS_Store'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "terser": "^5.0.0",
    "vite": "^8.0.10",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "topojson-client": "^3.1.0"
  }
}
